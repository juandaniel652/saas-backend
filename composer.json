{
    "name": "tuorg/core-saas-turnos",
    "description": "Core reutilizable para plataforma SaaS de gestion por turnos",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "firebase/php-jwt": "^7.1",
        "phpmailer/phpmailer": "^6.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
